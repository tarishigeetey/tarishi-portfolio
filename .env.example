# Environment Variables for Local Testing and Deployment
# Copy this to .env and fill in your API key for local testing
# DO NOT commit .env — it's in .gitignore

# Get a free Groq API key (no credit card required):
# https://console.groq.com/keys
#
# For local testing:
#   1. Copy this file to .env
#   2. Add your key below
#   3. Run: npm run dev
#   4. Bot will use the live LLM endpoint (/api/chat)
#
# For Vercel deployment:
#   1. Do NOT push .env to GitHub
#   2. In Vercel → Project Settings → Environment Variables
#   3. Add: GROQ_API_KEY = your_key_here
#   4. Redeploy

GROQ_API_KEY=

# Optional — only if you prefer Google Gemini over Groq
# Get a free key: https://aistudio.google.com/apikey
# Then see the note at the bottom of api/chat.js
# GEMINI_API_KEY=
